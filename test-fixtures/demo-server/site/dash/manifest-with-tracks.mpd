<?xml version="1.0" encoding="UTF-8"?>
<MPD xmlns="urn:mpeg:dash:schema:mpd:2011" type="static" mediaPresentationDuration="PT6S" minBufferTime="PT1.5S">
  <Period duration="PT6S">
    <AdaptationSet contentType="video" mimeType="video/mp4" codecs="avc1.4d401e">
      <Representation id="v1" bandwidth="750000" width="1280" height="720">
        <SegmentTemplate initialization="init.mp4" media="seg-$Number$.m4s" startNumber="1" duration="6" />
      </Representation>
    </AdaptationSet>
    <AdaptationSet contentType="audio" mimeType="audio/mp4" codecs="mp4a.40.2" lang="en">
      <Representation id="a1" bandwidth="128000">
        <SegmentTemplate initialization="init.mp4" media="seg-$Number$.m4s" startNumber="1" duration="6" />
      </Representation>
    </AdaptationSet>
  </Period>
</MPD>
