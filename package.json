{
  "name": "video-downloader-unshackle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:chrome": "wxt build --browser chrome",
    "build:firefox": "wxt build --browser firefox",
    "build:all": "npm run build:chrome && npm run build:firefox",
    "zip": "wxt zip",
    "zip:chrome": "wxt zip --browser chrome",
    "zip:firefox": "wxt zip --browser firefox",
    "test": "vitest run --config vitest.config.ts",
    "coverage": "vitest run --config vitest.config.ts --coverage --pool=vmThreads --maxWorkers=4",
    "coverage:badge": "node scripts/coverage-badge.mjs",
    "release:check": "node scripts/release-checks.mjs",
    "publish:firefox": "node scripts/publish-firefox.mjs",
    "native:build": "tsc -p native/ffmpeg-helper/tsconfig.json",
    "native:test": "vitest run --config vitest.config.ts native/ffmpeg-helper/src",
    "native:setup:windows": "powershell -ExecutionPolicy Bypass -File native/ffmpeg-helper/scripts/setup-windows.ps1",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "hls.js": "^1.6.16",
    "mux.js": "^6.3.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "0.1.25",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitest/coverage-v8": "4.1.5",
    "@wxt-dev/module-react": "1.2.2",
    "jsdom": "27.0.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "wxt": "0.20.25"
  }
}
